  },
  "clock": {
    "format": "{:%H:%M:%S}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"interval": 1
  },
	"bluetooth": {
		"format-no-controller": "X",
		"format": "status",
		"format-on": "َ°‚¯",
