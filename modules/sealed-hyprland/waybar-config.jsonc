{
  "battery": {
    "bat": "BAT0",
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% َ°‚„",
    "format-full": "{capacity}% {icon}",
    "format-icons": [
      "َ°‚ژ",
      "َ°پ؛",
