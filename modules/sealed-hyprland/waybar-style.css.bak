* {
    border: none;
    border-radius: 0;
    font-family: "Noto Sans", "Symbols Nerd Font", "Font Awesome 6 Free", sans-serif;
    font-size: 12px;
    min-height: 0;
}

window#waybar {
    background: transparent;
}

/* Main bar styling - smaller height */
#waybar {
    background-color: rgba(10, 14, 26, 0.95);
    color: #e8eaf0;
}

/* Individual module styling with rounded borders and smaller padding */
#workspaces button,
#clock,
#battery,
#cpu,
#memory,
#temperature,
#backlight,
#network,
#pulseaudio,
#tray,
#mode,
#custom-media {
    padding: 3px 8px;
    margin: 3px 2px;
    background-color: #1e3a5f;
    border-radius: 15px;
    color: #e8eaf0;
}

/* Workspace buttons */
#workspaces button {
    background-color: #141b2d;
    color: #a0a8c0;
    padding: 3px 6px;
}

#workspaces button.active {
    background-color: #2c5aa0;
    color: #ffffff;
}

#workspaces button.urgent {
    background-color: #8b2c3a;
}

#workspaces button:hover {
    background-color: #1e3a5f;
    transition: all 0.3s ease;
}

/* Clock styling */
#clock {
    background-color: #2c5aa0;
    font-weight: bold;
}

/* Battery styling with color states */
#battery {
    background-color: #1e3a5f;
}

#battery.charging {
    background-color: #2d5a3a;
}

#battery.warning:not(.charging) {
    background-color: #8b5a2c;
}

#battery.critical:not(.charging) {
    background-color: #8b2c3a;
    animation: blink 0.5s linear infinite;
}

@keyframes blink {
    to {
        opacity: 0.5;
    }
}

/* Network styling */
#network.disconnected {
    background-color: #8b2c3a;
}

/* Pulseaudio (volume) */
#pulseaudio.muted {
    background-color: #5a3a3a;
    color: #a0a8c0;
}

/* Tray */
#tray {
    background-color: #141b2d;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
}

/* Tooltip styling */
tooltip {
    background-color: #1e3a5f;
    border: 1px solid #2c5aa0;
    border-radius: 8px;
    color: #e8eaf0;
}

tooltip label {
    color: #e8eaf0;
}
